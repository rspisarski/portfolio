---
import Layout from '../layouts/Layout.astro';
import ContactInfo from '../components/ContactInfo.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="GitHub stats"
	description="GitHub contribution and language statistics for Richard Pisarski."
>
	<div class="flex flex-col min-h-screen">
		<main id="main-content" tabindex="-1" class="overflow-x-hidden pt-24 flex-grow outline-none">
			<div class="max-w-screen-md mx-auto px-4">
				<ContactInfo />
				<div class="flex flex-col gap-4">
					<img src="https://streak-stats.demolab.com?user=rspisarski&theme=default&hide_border=true" alt="GitHub contribution streak for rspisarski" />
					<img src="https://github-readme-stats.vercel.app/api?username=rspisarski&theme=default&show_icons=true&hide_border=true&count_private=true" alt="GitHub profile summary for rspisarski: contributions, stars, and activity" />
					<img src="https://github-readme-stats.vercel.app/api/top-langs/?username=rspisarski&theme=default&hide_border=true&layout=compact" alt="Most used programming languages on GitHub for rspisarski" />
				</div>
			</div>
		</main>
		<Footer />
	</div>
</Layout>

